# ===== Cloudinary =====
# Only cloud name + unsigned upload preset are needed in the browser.
# DO NOT put Cloudinary API Key or API Secret here — both are server-only.

VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name

# ===== Firebase =====
# These values are client-side Firebase config. Unlike Cloudinary's API
# Secret, the Firebase apiKey is an identifier, not a credential — it
# is safe to ship to the browser. Real protection comes from:
#   1. Firestore / Storage Security Rules
#   2. Restricting the API key by HTTP referrer in Google Cloud Console
#   3. (Optional) Firebase App Check
# The values still live in env so they are easy to rotate / swap.

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
