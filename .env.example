# Cloudinary configuration (client-side display only)
#
# Only the cloud name is needed to build delivery URLs. It is part of
# every public image URL, so it is safe to expose to the browser.
#
# DO NOT put your Cloudinary API Key or API Secret in this file or any
# other file that is committed to the repository. Those credentials are
# only needed for server-side operations (signed uploads, admin API) and
# must stay on trusted servers / local developer machines.

VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
