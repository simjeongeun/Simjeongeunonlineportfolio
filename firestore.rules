rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Site content lives under /content/*. Reads are public, writes are
    // allowed only to authenticated users whose email is in the admin
    // allow-list (/content/admins.emails). The very first authenticated
    // write is also allowed so the allow-list can be bootstrapped — once
    // the admins doc exists, only listed emails may write.
    match /content/{doc=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email != null
        && (
          !exists(/databases/$(database)/documents/content/admins)
          || request.auth.token.email.lower() in
               get(/databases/$(database)/documents/content/admins).data.emails
        );
    }
  }
}
